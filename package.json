{
  "name": "budget-matter",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "generate:content": "node scripts/generate-content.mjs",
    "dev": "npm run generate:content && vite --configLoader runner",
    "build": "npm run generate:content && tsc -b && vite build --configLoader runner",
    "start": "node server.mjs",
    "test": "npm run generate:content && vitest run --configLoader runner",
    "test:coverage": "npm run generate:content && vitest run --coverage --configLoader runner",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "cheerio": "^1.1.2",
    "express": "^5.1.0",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
